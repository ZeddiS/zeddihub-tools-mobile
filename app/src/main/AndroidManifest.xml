<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <!--
      Smart Reminders (v0.8.0) need exact alarms so a 09:00 medication
      reminder really fires at 09:00, not "sometime in the next hour" the
      way Doze would batch inexact alarms. Android 12+ also wants
      RECEIVE_BOOT_COMPLETED so we can rearm pending alarms after a reboot.
    -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- WiFi scanner (needs location per Android 9+) -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />
    <uses-permission android:name="android.permission.NEARBY_WIFI_DEVICES"
        android:usesPermissionFlags="neverForLocation"
        tools:targetApi="tiramisu" />

    <!-- PDF Scanner -->
    <uses-permission android:name="android.permission.CAMERA" />

    <!-- Decibel Meter -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Advanced NFC Tools: read/write NDEF tags when activity is in foreground. -->
    <uses-permission android:name="android.permission.NFC" />
    <uses-feature android:name="android.hardware.nfc" android:required="false" />

    <!--
      Bluetooth Tools (v0.9.0). Permissions split across API levels:
      • Legacy BLUETOOTH / BLUETOOTH_ADMIN = device API 30 and below.
      • BLUETOOTH_SCAN / BLUETOOTH_CONNECT = API 31+ (Android 12).
      We declare both so the same APK works across the full supported
      range. neverForLocation tells the system we're not deriving the
      user's position from BT scan results.
    -->
    <uses-permission android:name="android.permission.BLUETOOTH"
        android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN"
        android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation"
        tools:targetApi="s" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT"
        tools:targetApi="s" />
    <uses-feature android:name="android.hardware.bluetooth" android:required="false" />
    <uses-feature android:name="android.hardware.bluetooth_le" android:required="false" />

    <!-- USB host (OTG) tools — kernel exposes UsbManager without a permission
         declaration, but the host feature needs to be marked optional so we
         don't filter ourselves off non-OTG devices. -->
    <uses-feature android:name="android.hardware.usb.host" android:required="false" />

    <!-- Multi Remote — IR blaster tool. Optional because most modern phones
         lack the emitter; the screen detects this and tells the user. -->
    <uses-permission android:name="android.permission.TRANSMIT_IR" />
    <uses-feature android:name="android.hardware.consumerir" android:required="false" />

    <!-- Phonecall Recorder — see CallRecorderScreen.kt KDoc for the
         legal + technical caveats. WRITE_EXTERNAL_STORAGE is only needed
         on API 28 and earlier; on API 29+ we use scoped storage. -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />

    <!--
      v1.8.5 — extended Smart Reminders triggers.
      • ACCESS_BACKGROUND_LOCATION needed for geofence reminders to fire
        while the app isn't in the foreground (API 29+).
      • BLUETOOTH_ADVERTISE for the new BT advertising sub-tool.
    -->
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION"
        tools:targetApi="q" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADVERTISE"
        tools:targetApi="s" />

    <!-- Flashlight -->
    <uses-feature android:name="android.hardware.camera.flash" android:required="false" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <!--
      App Finder needs to enumerate installed apps (Android 11+ package
      visibility). QUERY_ALL_PACKAGES is the only way to see the full list,
      including non-launcher apps, services, and system packages.
      Play-Console restriction: justified by an explicit user-facing tool that
      lists installed apps; disclosure required in Data Safety form.
    -->
    <uses-permission
        android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />

    <!-- Fallback for builds that choose not to declare QUERY_ALL_PACKAGES. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="http" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="https" />
        </intent>
        <intent>
            <action android:name="android.intent.action.SENDTO" />
            <data android:scheme="mailto" />
        </intent>
        <intent>
            <action android:name="android.intent.action.SEND" />
            <data android:mimeType="*/*" />
        </intent>
    </queries>

    <application
        android:name=".ZeddiHubApp"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.ZeddiHub"
        android:usesCleartextTraffic="false">

        <!--
          launchMode="singleTask" + singleInstancePerTask=false guarantee that
          only one MainActivity ever exists. A second launch (from launcher,
          shortcut, deeplink, or update-install) is routed to onNewIntent on
          the existing instance instead of spawning a duplicate window.

          documentLaunchMode="never" prevents OEM "parallel window" features
          (Samsung DeX, tablets) from cloning the activity into a new document.
        -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:documentLaunchMode="never"
            android:excludeFromRecents="false"
            android:theme="@style/Theme.ZeddiHub"
            android:configChanges="orientation|screenSize|screenLayout|smallestScreenSize|keyboardHidden|uiMode|density|fontScale"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
          Smart Reminders broadcast receiver. Fires when an AlarmManager alarm
          goes off; not exported because we never want third-party apps to
          spoof reminder firings. The boot receiver re-arms persisted rules
          after device restart since AlarmManager forgets them.
        -->
        <receiver
            android:name="com.zeddihub.mobile.data.reminders.ReminderReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.zeddihub.mobile.REMINDER_FIRE" />
            </intent-filter>
        </receiver>
        <receiver
            android:name="com.zeddihub.mobile.data.reminders.ReminderBootReceiver"
            android:exported="true"
            android:enabled="true"
            android:permission="android.permission.RECEIVE_BOOT_COMPLETED">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

        <!-- v1.8.5: Geofence transitions are delivered via this receiver
             whenever the device crosses any of the registered fences. -->
        <receiver
            android:name="com.zeddihub.mobile.data.reminders.ReminderGeofenceReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.zeddihub.mobile.REMINDER_GEOFENCE" />
            </intent-filter>
        </receiver>

        <!--
          We provide our own WorkManager Configuration via
          ZeddiHubApp.workManagerConfiguration so HiltWorkerFactory can
          inject dependencies into ReminderWeatherWorker. Disabling the
          default initialiser is mandatory — otherwise WorkManager spins
          up first with a no-arg factory and our config never runs.
        -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- FCM service – odkomentovat po přidání Firebase -->
        <!--
        <service
            android:name=".fcm.ZeddiFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>
        -->
    </application>
</manifest>
